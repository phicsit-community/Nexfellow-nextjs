<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Password Reset - NexFellow</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f0f4f8;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .container {
            max-width: 480px;
            background: #fff;
            padding: 40px;
            margin-top: 5rem;
            border-radius: 12px;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
        }

        h2 {
            text-align: center;
            margin-bottom: 40px;
            font-weight: 700;
            color: #333;
        }

        .form-group label {
            font-weight: 600;
            color: #555;
        }

        button.btn-primary,
        button.btn-success {
            background: linear-gradient(135deg, #08AAA2, #5CD7D1);
            border: none;
            font-weight: 600;
            transition: background 0.3s ease;
        }

        button.btn-primary:hover,
        button.btn-success:hover {
            background: linear-gradient(135deg, #069088, #45b2aa);
        }

        .spinner-border {
            display: none;
            margin-top: 15px;
        }

        #message,
        #otpMessage {
            margin-top: 20px;
            text-align: center;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .cursor-pointer {
            cursor: pointer;
        }
    </style>
</head>

<body>
    <div class="container">
        <h2>Password Reset</h2>

        <!-- Step 1: Password Reset Form -->
        <form id="resetForm" action="/user/resetpassword/<%= id %>/<%= token %>" method="POST" novalidate>
            <div class="form-group">
                <label for="password">Enter New Password</label>
                <input type="password" class="form-control" id="password" name="password"
                    placeholder="At least 4 characters" required minlength="4" autocomplete="new-password"
                    oninvalid="this.setCustomValidity('Please enter a valid password with minimum 4 characters')"
                    oninput="this.setCustomValidity('')" />
            </div>
            <button type="submit" class="btn btn-primary btn-block" id="resetSubmitBtn">Reset Password</button>
            <div class="text-center">
                <div id="resetSpinner" class="spinner-border text-primary" role="status" aria-hidden="true"></div>
            </div>
        </form>

        <!-- Step 2: Email input to request OTP -->
        <form id="emailForm" style="display:none;" novalidate>
            <div class="form-group mt-3">
                <label for="emailOtp">Email Address</label>
                <input type="email" id="emailOtp" class="form-control" placeholder="Enter your registered email"
                    required autocomplete="email"
                    oninvalid="this.setCustomValidity('Please provide a valid email address')"
                    oninput="this.setCustomValidity('')" />
            </div>
            <button type="submit" class="btn btn-primary btn-block" id="emailSubmitBtn">Send OTP</button>
            <div class="text-center">
                <div id="emailSpinner" class="spinner-border text-primary" role="status" aria-hidden="true"></div>
            </div>
        </form>

        <!-- Step 3: OTP verification Form -->
        <form id="otpForm" style="display:none;" novalidate>
            <div class="form-group mt-3">
                <label for="otp">Enter the OTP</label>
                <input type="text" id="otp" class="form-control" placeholder="One-time password" required minlength="4"
                    maxlength="6" pattern="\d{4,6}"
                    oninvalid="this.setCustomValidity('Please enter a valid numeric OTP')"
                    oninput="this.setCustomValidity('')" />
            </div>
            <button type="submit" class="btn btn-success btn-block" id="otpSubmitBtn">Verify OTP</button>
            <button type="button" id="resendOtpBtn" class="btn btn-link d-block mt-3 p-0 m-auto text-center"
                style="max-width: 180px;">Resend OTP</button>
            <div class="text-center">
                <div id="otpSpinner" class="spinner-border text-primary" role="status" aria-hidden="true"></div>
            </div>
        </form>

        <!-- Feedback message -->
        <div id="message" aria-live="polite" role="alert"></div>
    </div>

    <script>
        (() => {
            const resetForm = document.getElementById('resetForm');
            const emailForm = document.getElementById('emailForm');
            const otpForm = document.getElementById('otpForm');

            const messageDiv = document.getElementById('message');

            const resetSubmitBtn = document.getElementById('resetSubmitBtn');
            const emailSubmitBtn = document.getElementById('emailSubmitBtn');
            const otpSubmitBtn = document.getElementById('otpSubmitBtn');
            const resendOtpBtn = document.getElementById('resendOtpBtn');

            const resetSpinner = document.getElementById('resetSpinner');
            const emailSpinner = document.getElementById('emailSpinner');
            const otpSpinner = document.getElementById('otpSpinner');

            // Utility: show message
            function showMessage(text, type = 'info') {
                messageDiv.textContent = text;
                messageDiv.style.color = (type === 'error') ? '#d9534f'
                    : (type === 'success') ? '#5cb85c'
                        : '#333';
            }

            // Clear message
            function clearMessage() {
                messageDiv.textContent = '';
            }

            // Show spinner helper
            function toggleSpinner(spinner, show) {
                spinner.style.display = show ? 'inline-block' : 'none';
            }

            // Reset Password submission
            resetForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                clearMessage();

                resetSubmitBtn.disabled = true;
                toggleSpinner(resetSpinner, true);

                const password = resetForm.password.value;

                try {
                    const res = await fetch(resetForm.action, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ password }),
                    });

                    const data = await res.json().catch(() => ({}));

                    toggleSpinner(resetSpinner, false);
                    resetSubmitBtn.disabled = false;

                    if (res.ok) {
                        showMessage('Password reset successful! You may now log in.', 'success');
                        resetForm.style.display = 'none';
                    } else {
                        if (data === 'invalid token' || data.message === 'invalid token') {
                            showMessage('Your reset token is invalid or expired. Please verify your email via OTP.', 'error');
                            resetForm.style.display = 'none';
                            emailForm.style.display = 'block';
                            clearInputs();
                        } else {
                            showMessage(data.message || 'Error resetting password.', 'error');
                        }
                    }
                } catch (error) {
                    toggleSpinner(resetSpinner, false);
                    resetSubmitBtn.disabled = false;
                    showMessage('Network error. Please try again.', 'error');
                }
            });

            // Email form submission: request OTP
            emailForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                clearMessage();

                emailSubmitBtn.disabled = true;
                toggleSpinner(emailSpinner, true);

                const emailInput = emailForm.emailOtp.value.trim();

                if (!emailInput) {
                    showMessage('Please enter your email address.', 'error');
                    toggleSpinner(emailSpinner, false);
                    emailSubmitBtn.disabled = false;
                    return;
                }

                try {
                    const res = await fetch('/user/requestResetOtp', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email: emailInput }),
                    });

                    const data = await res.json();

                    toggleSpinner(emailSpinner, false);
                    emailSubmitBtn.disabled = false;

                    if (res.ok) {
                        showMessage('OTP sent to your email. Please check your inbox.', 'success');
                        emailForm.style.display = 'none';
                        otpForm.style.display = 'block';
                    } else {
                        showMessage(data.message || 'Failed to send OTP. Please try again.', 'error');
                    }
                } catch {
                    toggleSpinner(emailSpinner, false);
                    emailSubmitBtn.disabled = false;
                    showMessage('Network error. Please try again.', 'error');
                }
            });

            // OTP verification form submission
            otpForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                clearMessage();

                otpSubmitBtn.disabled = true;
                toggleSpinner(otpSpinner, true);

                const emailInput = emailForm.emailOtp.value.trim();
                const otpInput = otpForm.otp.value.trim();

                if (!otpInput) {
                    showMessage('Please enter the OTP.', 'error');
                    toggleSpinner(otpSpinner, false);
                    otpSubmitBtn.disabled = false;
                    return;
                }

                try {
                    const res = await fetch('/user/verifyResetOtp', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email: emailInput, otp: otpInput }),
                    });

                    const data = await res.json();

                    toggleSpinner(otpSpinner, false);
                    otpSubmitBtn.disabled = false;

                    if (res.ok) {
                        showMessage('OTP verified successfully! Please set a new password now.', 'success');
                        otpForm.style.display = 'none';
                        resetForm.style.display = 'block';
                        resetForm.password.value = '';
                    } else {
                        showMessage(data.message || 'OTP verification failed.', 'error');
                    }
                } catch {
                    toggleSpinner(otpSpinner, false);
                    otpSubmitBtn.disabled = false;
                    showMessage('Network error. Please try again.', 'error');
                }
            });

            // Resend OTP button handler
            resendOtpBtn.addEventListener('click', async () => {
                clearMessage();

                const emailInput = emailForm.emailOtp.value.trim();

                if (!emailInput) {
                    alert('Please enter your email address first.');
                    return;
                }

                resendOtpBtn.disabled = true;
                resendOtpBtn.textContent = 'Sending...';

                try {
                    const res = await fetch('/user/resendOtp', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email: emailInput }),
                    });

                    const data = await res.json();

                    if (res.ok) {
                        showMessage(data.message || 'OTP resent successfully.', 'success');
                    } else {
                        showMessage(data.message || 'Failed to resend OTP.', 'error');
                    }
                } catch {
                    showMessage('Network error. Please try again.', 'error');
                } finally {
                    resendOtpBtn.disabled = false;
                    resendOtpBtn.textContent = 'Resend OTP';
                }
            });

            // Helper to clear input fields on transitions
            function clearInputs() {
                resetForm.password.value = '';
                emailForm.emailOtp.value = '';
                otpForm.otp.value = '';
            }
        })();
    </script>
</body>

</html>